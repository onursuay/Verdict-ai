ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini bağlam denetçisi — sadece server-side. x-goog-api-key header üzerinden gönderilir.
# Frontend'e asla çıkmaz. Yoksa Gemini analizi mock olarak çalışır.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview

# Supabase OAuth — Supabase Management API erişimi (kullanıcı kendi hesabını bağlar)
# Yalnızca server-side. Client secret asla frontend'e çıkmaz; token URL'de taşınmaz.
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=
SUPABASE_OAUTH_REDIRECT_URI=https://verdictai.onursuay.com/api/auth/supabase/callback

# Supabase OAuth token şifreleme anahtarı (32 byte hex). openssl rand -hex 32 ile üret.
# Bu anahtar olmadan token'lar şifrelenemez ve Supabase OAuth bağlantı flow'u devre dışıdır.
CREDENTIAL_ENCRYPTION_KEY=

# GitHub repo okuma (FAZ 2A) — sadece server-side. Public repolar için
# olmayabilir; private repo veya rate limit için classic/fine-grained PAT.
# Sadece "Contents: read" izni yeterli. Frontend'e asla çıkmaz.
GITHUB_TOKEN=
