ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini bağlam denetçisi — sadece server-side. x-goog-api-key header üzerinden gönderilir.
# Frontend'e asla çıkmaz. Yoksa Gemini analizi mock olarak çalışır.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-pro-preview

# Supabase OAuth — Supabase Management API erişimi (kullanıcı kendi hesabını bağlar)
# Yalnızca server-side. Client secret asla frontend'e çıkmaz; token URL'de taşınmaz.
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=
SUPABASE_OAUTH_REDIRECT_URI=https://verdictai.onursuay.com/api/auth/supabase/callback

# Supabase OAuth token şifreleme anahtarı (32 byte hex). openssl rand -hex 32 ile üret.
# Bu anahtar olmadan token'lar şifrelenemez ve Supabase OAuth bağlantı flow'u devre dışıdır.
CREDENTIAL_ENCRYPTION_KEY=

# GitHub repo okuma (FAZ 2A) — sadece server-side. Public repolar için
# olmayabilir; private repo veya rate limit için classic/fine-grained PAT.
# Sadece "Contents: read" izni yeterli. Frontend'e asla çıkmaz.
GITHUB_TOKEN=

# ─── Audit Pipeline (FAZ 3) — env-driven limitler ─────────────────────────────
# Eski hard-code 80_000 / 25 dosya / 300 entry sınırları kaldırıldı.
# Default'lar geniş; gerekirse yukarı/aşağı değiştir.
VERDICT_AUDIT_CONTEXT_CHARS=200000
VERDICT_AUDIT_CONTEXT_HARD_CEILING=300000
VERDICT_GITHUB_TREE_LIMIT=5000
VERDICT_GITHUB_FILES_TO_READ=80
VERDICT_GITHUB_FILE_CHARS=40000
VERDICT_LOCAL_MAX_FILES=200
VERDICT_LOCAL_FILE_CHARS=40000
VERDICT_LOCAL_MAX_BYTES=5000000
VERDICT_SUPABASE_MAX_TABLES=200
VERDICT_SUPABASE_MAX_POLICIES=500
VERDICT_VERCEL_TIMEOUT_MS=8000
VERDICT_SUPABASE_TIMEOUT_MS=10000
VERDICT_WORKER_TIMEOUT_MS=5000

# Lokal yol audit'i için izinli prefix listesi. Boş ise lokal okuma DEVRE DIŞI.
# `:`, `,` veya `;` ile birden fazla prefix tanımlanabilir. Path traversal
# bunların ALTINDA kalmaya zorlanır.
# Örnek: /Users/onursuay/Desktop/Onur Suay/Web Siteleri:/Users/onursuay/projects
VERDICT_ALLOWED_LOCAL_PATH_PREFIXES=

# VPS/Worker heartbeat opsiyonel HTTP endpoint'i. Set ise audit anında GET atılır
# ve response JSON heartbeat tablosu yerine kullanılır. Header/Auth gerekmez;
# içeride çalışan worker bu endpoint'i imzasız expose etmelidir.
VERDICT_WORKER_HEARTBEAT_URL=
